# Copy this file to ".env" for local development and fill in real values.
# NEVER commit the real ".env" file — it is already listed in .gitignore.

# A long, random string used to sign sessions & cookies.
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-string

# Optional. If not set, the app falls back to a local SQLite database
# (instance/todo.db). On Render/Heroku this is provided automatically
# when you attach a Postgres database.
DATABASE_URL=sqlite:///todo.db

FLASK_ENV=development
